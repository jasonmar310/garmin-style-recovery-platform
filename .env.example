# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored; this template carries placeholders only (no real secrets).

# --- Kafka (KRaft) -----------------------------------------------------------
# Cluster id shared by all 3 brokers. Generate one with:
#   docker run --rm apache/kafka:3.8.0 /opt/kafka/bin/kafka-storage.sh random-uuid
CLUSTER_ID=replace-with-kafka-storage-random-uuid

# --- TimescaleDB (hot tier) --------------------------------------------------
TIMESCALE_DB=telemetry
TIMESCALE_USER=ian
TIMESCALE_PASSWORD=change-me
# Host port for TimescaleDB (5432 inside the container). 5433 dodges a local PG.
PGPORT=5433

# --- MinIO (cold tier, S3-compatible) ----------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me

# --- Airflow (medallion + DQ) ------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_PORT=8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me
# Fernet key for Airflow connection encryption. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# May be left empty for a throwaway local stack.
AIRFLOW_FERNET_KEY=

# --- Monitoring (Prometheus + Grafana) ---------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=change-me
