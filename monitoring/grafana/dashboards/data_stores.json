{
  "uid": "data-stores",
  "title": "3 · Data Stores",
  "tags": ["telemetry", "timescaledb"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "TimescaleDB up",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "pg_up", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active connections",
      "description": "Climbs under backpressure (scenario 3) as the router's writes queue up.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "pg_stat_database_numbackends{datname=\"telemetry\"}", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 90 }
          ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Connections vs max",
      "description": "Active backends against the server's max_connections ceiling.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "pg_stat_database_numbackends{datname=\"telemetry\"}", "legendFormat": "active", "refId": "A" },
        { "expr": "pg_settings_max_connections", "legendFormat": "max", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Commit rate (transactions/sec)",
      "description": "Write activity into TimescaleDB. Falls toward zero if the hot sink stalls.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ {
        "expr": "rate(pg_stat_database_xact_commit{datname=\"telemetry\"}[1m])",
        "legendFormat": "commits/s", "refId": "A"
      } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }, "unit": "ops", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Gold DQ status",
      "description": "Data-quality layer. 1=pass, 0=fail. Goes red when a gold metric is empty, drifted, or stale — even while infra is green.",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "min(dq_status)", "refId": "A" } ],
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "FAIL" }, "1": { "text": "PASS" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Gold freshness lag (days) by metric",
      "description": "Days each gold metric lags its source stream. >0 means a required input went silent (data-layer anomaly).",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "dq_freshness_lag_days", "legendFormat": "{{metric}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}